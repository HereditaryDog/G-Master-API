# Copy this file to .cloudflared-domain.env before starting a named Cloudflare Tunnel.
# The token comes from the Cloudflare dashboard after you create a tunnel.

CLOUDFLARE_TUNNEL_TOKEN=replace-with-your-cloudflare-tunnel-token
CLOUDFLARE_TUNNEL_HOSTNAME=gmapi.fun
TUNNEL_TARGET=http://127.0.0.1:3000
